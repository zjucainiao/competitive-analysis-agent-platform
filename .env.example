# ------------------------------------------------------------
# Application
# ------------------------------------------------------------
LOG_LEVEL=INFO

# ------------------------------------------------------------
# LLM Provider —— 至少填一组（优先级：豆包 > DeepSeek > OpenAI）
# ------------------------------------------------------------
# 方案 A · DeepSeek（最简单，base_url / model 有默认值，填 key 即可）
DEEPSEEK_API_KEY=
# DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
# DEEPSEEK_MODEL=deepseek-chat

# 方案 B · 豆包 Seed（火山方舟，OpenAI 兼容；填了优先用豆包。DOUBAO_MODEL 为 EP 接入点 ID）
DOUBAO_API_KEY=
DOUBAO_BASE_URL=
DOUBAO_MODEL=


TAVILY_API_KEY=
SERPER_API_KEY=

# Firecrawl 用于 JS 渲染抓取（SPA 站点）；空则 Collector 退回 httpx + Playwright
FIRECRAWL_API_KEY=

# ------------------------------------------------------------
# Storage
# ------------------------------------------------------------
# memory  ：单进程内存，零依赖（默认，重启即丢，适合先试用）
# postgres：持久化。三种起法任选——
#           · docker compose up -d postgres redis（推荐 / 部署）
#           · 本地无 Docker：python scripts/localdb.py up（嵌入式 pg+redis）
#           · 自带 / 托管云 pg：直接把连接串填到 POSTGRES_DSN
STORAGE_MODE=memory
POSTGRES_DSN=postgresql+asyncpg://app:app@localhost:5432/app
REDIS_URL=redis://localhost:6379/0

# ------------------------------------------------------------
# 鉴权
# ------------------------------------------------------------
# JWT 签名密钥：生产必须设一个长随机串（>=32 字节，如 `openssl rand -hex 32`）。
# 不设时按 STORAGE_MODE 区别对待：
#   memory  ：回退不安全的开发默认值并打印告警（本地试用低摩擦）
#   postgres：生产形态，直接拒绝启动；本地 postgres 验证（localdb 等）
#             确需跳过时可显式设 JWT_ALLOW_INSECURE_DEV=1（自担风险）
JWT_SECRET=

# 注册/登录白名单：
#   不设 / *  ：开放注册（默认）
#   邮箱列表  ：仅这些邮箱可注册登录（私有部署锁定自己的账号，逗号分隔）
# AUTH_ALLOWED_EMAILS=you@example.com

# ------------------------------------------------------------
# Agent / Orchestrator 行为微调（可选）
# ------------------------------------------------------------
# QA 反馈循环上限（超过强制发布）
QA_MAX_ROUNDS=3

# Trace / Tool 调试（v1 用 NullTracer，留待 I 窗口 OTLP 接入）
TRACE_RETENTION_DAYS=7
# 编排引擎:native(原生 LangGraph,Phase 2 起默认)。回退旧自研解释器用 legacy。
ORCH_ENGINE=native
