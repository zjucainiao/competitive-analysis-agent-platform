# =========================================
#  Competitive Analysis Agent Platform
#  Example environment variables
#  Copy to .env and fill in real values
# =========================================

# --- App ---
APP_MODE=hybrid                   # mock / hybrid / real
LOG_LEVEL=INFO
TRACE_RETENTION_DAYS=90

# --- LLM Provider ---
LLM_DEFAULT_PROVIDER=anthropic    # anthropic / openai / deepseek / qwen
LLM_DEFAULT_MODEL=claude-sonnet-4-6
LLM_PLANNER_MODEL=claude-opus-4-7
LLM_TEMPERATURE_DEFAULT=0.2

ANTHROPIC_API_KEY=
OPENAI_API_KEY=
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
QWEN_API_KEY=
QWEN_BASE_URL=

# --- Tools ---
TAVILY_API_KEY=
SERPER_API_KEY=
FIRECRAWL_API_KEY=
FIRECRAWL_BASE_URL=https://api.firecrawl.dev

# --- Storage ---
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/competitive_analysis
CHROMA_PERSIST_DIR=./.chroma
REDIS_URL=redis://localhost:6379/0

# --- Observability (Optional) ---
LANGCHAIN_API_KEY=
LANGCHAIN_TRACING_V2=false
LANGCHAIN_PROJECT=competitive-analysis

# --- Cost limits ---
PROJECT_COST_SOFT_LIMIT_USD=10
PROJECT_COST_HARD_LIMIT_USD=50

# --- Collector defaults ---
COLLECTOR_RESPECT_ROBOTS_TXT=true
COLLECTOR_REQ_PER_SECOND=1
COLLECTOR_USER_AGENT=CompetitiveAnalysisBot/1.0
