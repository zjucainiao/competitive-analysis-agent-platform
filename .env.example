# ------------------------------------------------------------
# Application
# ------------------------------------------------------------
LOG_LEVEL=INFO

# ------------------------------------------------------------
# LLM Provider
# ------------------------------------------------------------
DOUBAO_API_KEY=
DOUBAO_BASE_URL=
DOUBAO_MODEL=





TAVILY_API_KEY=
SERPER_API_KEY=

# Firecrawl 用于 JS 渲染抓取（SPA 站点）；空则 Collector 退回 httpx + Playwright
FIRECRAWL_API_KEY=

# ------------------------------------------------------------
# Storage（可选，默认进程内存）
# ------------------------------------------------------------
# memory：单进程内存，零依赖（默认）
# postgres：要 docker compose up -d postgres redis
STORAGE_MODE=memory
POSTGRES_DSN=postgresql+asyncpg://app:app@localhost:5432/app
REDIS_URL=redis://localhost:6379/0

# ------------------------------------------------------------
# Agent / Orchestrator 行为微调（可选）
# ------------------------------------------------------------
# QA 反馈循环上限（超过强制发布）
QA_MAX_ROUNDS=3

# Trace / Tool 调试（v1 用 NullTracer，留待 I 窗口 OTLP 接入）
TRACE_RETENTION_DAYS=7