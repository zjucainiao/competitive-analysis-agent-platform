# ════════════════════════════════════════════════════════════════════════
#  生产环境变量模板。复制为 .env.prod 并填真实值：
#      cp .env.prod.example .env.prod && vim .env.prod
#  .env.prod 含密钥，已被 .gitignore 排除，切勿提交。
#
#  启动：
#      docker compose --env-file .env.prod -f docker-compose.prod.yml up -d --build
# ════════════════════════════════════════════════════════════════════════

# ── 域名 & HTTPS（Caddy 自动签证书）─────────────────────────────────────
# DNS 里把这个域名的 A 记录指到本服务器公网 IP，证书才能签发成功。
DOMAIN=yourdomain.com
ACME_EMAIL=you@example.com

# 前端跨域白名单。同源部署照抄 https://<DOMAIN> 即可；多个用逗号分隔。
CORS_ORIGINS=https://yourdomain.com

# ── LLM：DeepSeek ───────────────────────────────────────────────────────
# 只填 DEEPSEEK_API_KEY 时自动用 DeepSeek（优先级 DOUBAO > DEEPSEEK > OPENAI）。
DEEPSEEK_API_KEY=sk-xxxxxxxxxxxxxxxx
# 下面两个有默认值，一般不用动：
# DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
# DEEPSEEK_MODEL=deepseek-chat
# 成本指标更准（可选）：每百万 token 的 输入,输出 价（美元）。
LLM_PRICING_DEEPSEEK_CHAT=0.27,1.10

# ── 搜索 key（DeepSeek 必填一个！）──────────────────────────────────────
# DeepSeek 没有自带联网搜索，collector 要靠它发现竞品来源 URL。
# 不配的话采集会退回 mock 数据（出不了真实分析）。Tavily 最简单，二选一即可。
TAVILY_API_KEY=tvly-xxxxxxxxxxxxxxxx
# SERPER_API_KEY=xxxxxxxxxxxxxxxx
# 可选：网页抓取增强（带 markdown / onlyMainContent）。不配则走 httpx 基础抓取。
# FIRECRAWL_API_KEY=fc-xxxxxxxxxxxxxxxx

# ── 鉴权 ────────────────────────────────────────────────────────────────
# 必须改成强随机串，生成：  openssl rand -hex 32
JWT_SECRET=CHANGE_ME_openssl_rand_hex_32

# ── 数据库密码 ──────────────────────────────────────────────────────────
# compose 用它起 Postgres 容器并拼 POSTGRES_DSN。改成强密码。
POSTGRES_PASSWORD=CHANGE_ME_strong_db_password

# ── 编排 / 质检 / 日志（都有默认值，可不改）──────────────────────────────
ORCH_ENGINE=native          # native（默认）/ legacy
QA_MAX_ROUNDS=3
LOG_LEVEL=INFO
TRACE_RETENTION_DAYS=7

# 可选：把 LLM/agent span 落到外部 Jaeger/Tempo（不配则不导出 trace）。
# OTEL_EXPORTER_OTLP_ENDPOINT=http://your-collector:4318
# OTEL_SERVICE_NAME=competitive-analysis-agent

# ── 不要在这里设以下变量 ────────────────────────────────────────────────
# STORAGE_MODE / POSTGRES_DSN / REDIS_URL 由 docker-compose.prod.yml 注入
# （指向容器内 postgres / redis），在这里设会被覆盖、还容易写错 host。
